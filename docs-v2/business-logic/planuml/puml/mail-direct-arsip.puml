@startuml
!theme plain
title directArsip() - Arsip Langsung dari Surat\ndirect/mail.php:364-390

start

:Gate 1 Role Permission Check;
partition "Cek Hak Akses" #LightBlue {
  :Query role menu event;
}
if (Akses menu arsip?) then (no)
  :Return ERROR: tidak punya hak arsip;
  stop
else (yes)
endif

:Gate 2 Duplicate Check;
partition "Cek Duplikat Arsip" #LightBlue {
  :Get mail by id_mail;
  :Get root mail by m_root_id;
}
if (Root mail sudah punya m_ma_id?) then (yes)
  :Return ERROR: surat sudah diarsipkan;
  stop
else (no)
endif

:Gate 3 Attachment Check;
if (m_attachment_qty > 0?) then (yes)
  :temp_id = get_temp_id(user_id);
  :copy_attachments REF_TYPE_MAIL -> REF_TYPE_MAIL_ARCHIVE;
  :Return SUCCESS with temp_id and root mail data;
else (no)
  :Return ERROR: surat tidak memiliki lampiran;
  stop
endif

stop
@enduml
