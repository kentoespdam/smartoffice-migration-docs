@startuml mail-sign
!theme plain
skinparam shadowing false
skinparam wrapWidth 220
title signMe() + checkSign() - Verifikasi Cetak Surat\ndirect/mail.php:395-419

start

if (Action?) then (signMe)
  :signMe() - Generate Verification Code;
  :direct/mail.php:395-405;

  :User mencetak surat (print action);

  partition "Generate Auth Code" #LightBlue {
    :auth_code = uniqid();
    note right
      PHP uniqid() menghasilkan
      unique ID berbasis timestamp.
      Contoh: "65f8a3b2e4d01"

      Migrasi: ini bukan digital signature.
      Hanya print verification code.
      Di Spring Boot, gunakan UUID
      atau JWT untuk keamanan lebih baik.
    end note

    :INSERT print_log:
    - auth_code = generated code
    - date = now()
    - mail_id = id_mail
    - username = user_full_name
    - ip_address = client IP;
  }

  :Return { code: auth_code };
  note right
    Code ini ditampilkan di
    hasil cetak surat (biasanya
    di footer atau sebagai QR code)
  end note
else (checkSign)
  :checkSign() - Verify Printed Document;
  :direct/mail.php:410-419;

  :Input: key (auth_code dari dokumen);

  partition "Lookup Verification" #LightBlue {
    :SELECT s.*, print_date, m_date,
    m_subject, m_content
    FROM print_log s
    JOIN mail m ON m.m_id = s.mail_id
    WHERE s.auth_code = key;
  }

  if (record ditemukan?) then (yes)
    :Render view "cek_signature.html"
    dengan data:
    - Informasi penandatangan (username)
    - Tanggal cetak (print_date)
    - Tanggal surat (m_date)
    - Perihal surat (m_subject)
    - Isi surat (m_content)
    - Kode verifikasi (key);
    note right
      Halaman ini bisa diakses
      publik untuk verifikasi
      keaslian dokumen cetak.

      Migrasi:
      GET /api/mails/verify-sign/{key}
      Return JSON, bukan HTML view.
    end note
  else (no)
    #Pink:Tampilkan halaman\n"Kode tidak valid";
  endif
endif

stop

@enduml
